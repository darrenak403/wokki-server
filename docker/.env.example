# Dev:  cp docker/.env.example docker/.env.local  →  task docker:build
# Prod: cp docker/.env.example docker/.env        →  task docker:prod
# task run: User Secrets (docker/README.md)

# Postgres
POSTGRES_USER=wokki
POSTGRES_PASSWORD=your_password
POSTGRES_DB=wokki
POSTGRES_PORT=5432

# Redis (OTP)
REDIS_PORT=6379

# App
DB_UI_PORT=8888
API_PORT=8386
ASPNETCORE_ENVIRONMENT=Development
DATABASE_AUTOMIGRATE=true
APIDOCS_ENABLED=true

# JWT
JWT_ISSUER=wokki
JWT_AUDIENCE=wokki-api
JWT_SECRET=your_secret_key_min_32_chars
JWT_ACCESS_TOKEN_MINUTES=60

# AWS — Bedrock only
# https://console.aws.amazon.com/iam → Access key
# https://console.aws.amazon.com/bedrock → Model access
AWS_REGION=us-west-2
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
BEDROCK_MODEL_ID=google.gemma-3-27b-it

# Brevo SMTP
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_USE_SSL=true
SMTP_FROM=noreply@your-domain.com
SMTP_USERNAME=
SMTP_PASSWORD=

# Prod (pgAdmin)
DB_UI_EMAIL=admin@your-domain.com
DB_UI_PASSWORD=your_pgadmin_password
