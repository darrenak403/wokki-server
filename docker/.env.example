# Dev:  cp docker/.env.example docker/.env.local  →  task docker:build
# Prod: cp docker/.env.example docker/.env        →  task docker:prod
# Dokploy: copy các biến PROD vào tab Environment của app (không cần file .env trên server)
# GitHub Secrets (chỉ CI): DOCKER_USERNAME, DOCKER_PASSWORD — KHÔNG ghi password vào file này

# =============================================================================
# PROD — Docker / Dokploy (bắt buộc)
# =============================================================================
DOCKER_USERNAME=REPLACE_ME_DOCKERHUB_USERNAME  # VD: darrenak403 — KHÔNG để placeholder
IMAGE_TAG=latest

# =============================================================================
# Postgres
# =============================================================================
POSTGRES_USER=wokki
POSTGRES_PASSWORD=your_strong_password
POSTGRES_DB=wokki
POSTGRES_PORT=5432

# =============================================================================
# Redis
# =============================================================================
REDIS_PORT=6379
REDIS_MAXMEMORY=256mb

# =============================================================================
# App
# =============================================================================
API_PORT=8386
DATABASE_AUTOMIGRATE=true  # false sau khi DB đã migrate lần đầu
APIDOCS_ENABLED=false
CORS_ALLOW_ANY_ORIGIN=true

# JWT
JWT_ISSUER=wokki
JWT_AUDIENCE=wokki-api
JWT_SECRET=your_secret_key_min_32_chars
JWT_ACCESS_TOKEN_MINUTES=60

# AWS — Bedrock
AWS_REGION=us-west-2
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
BEDROCK_MODEL_ID=google.gemma-3-27b-it

# Brevo SMTP
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_USE_SSL=true
SMTP_FROM=noreply@your-domain.com
SMTP_USERNAME=
SMTP_PASSWORD=

# Cloudinary
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# DbGate (admin DB — bind 127.0.0.1)
DBGATE_PORT=5050

# =============================================================================
# PROD — tùy chọn (RAM limits)
# =============================================================================
# API_MEMORY_LIMIT=1024M
# POSTGRES_MEMORY_LIMIT=768M
# REDIS_MEMORY_LIMIT=384M

# =============================================================================
# DEV only (chỉ dùng trong .env.local)
# =============================================================================
# ASPNETCORE_ENVIRONMENT=Development
# DATABASE_AUTOMIGRATE=true
# APIDOCS_ENABLED=true
# DB_UI_PORT=8888
